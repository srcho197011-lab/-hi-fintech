# ───────────────────────────────────────────────────────────
#  배포에 '필요한 파일만' GitHub에 올립니다 (화이트리스트 방식).
#  먼저 전부 무시(/*)한 뒤, 아래 항목만 다시 허용(!)합니다.
#  → 설치파일(.exe)·zip·pdf·docx·설계문서·이미지폴더 등 무거운
#    비(非)웹 파일이 실수로 올라가는 것을 막아줍니다.
# ───────────────────────────────────────────────────────────
/*

# 배포에 필요한 것만 허용
!/.gitignore
!/index.html
!/vercel.json
!/README.md
!/build_preview.sh
!/data
!/src

# 펫 사이트(HI-PET) — Vercel 루트 디렉터리로 배포
!/pet
# 휴먼 사이트 공유 썸네일(OG)
!/og-human.png
# 펫 설계계획서(참고용)
!/PetHealth_InsurFin_설계계획서.md
# 교육용 데이터 수집 도구(다운로드 산출물은 tools 내부 .gitignore로 제외)
!/tools

# (data 폴더 안 임시/불필요 파일이 생기면 여기에 추가로 제외)
